{
	"name": "@aobayos/react-reactive-forms",
	"version": "0.1.0",
	"type": "module",
	"description": "Simple library to handle reactive forms for React apps, inspired by Angular Forms",
	"license": "MIT",
	"main": "./dist/index.umd.cjs",
	"module": "./dist/index.js",
